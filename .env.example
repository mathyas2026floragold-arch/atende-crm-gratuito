# =========================================================
# ATENDE CRM — copie para .env SOMENTE dentro do servidor
# Nunca envie o arquivo .env para o GitHub.
# =========================================================

APP_ENV=production

# Endereço gratuito. Troque 203-0-113-10 pelo IP público da sua Oracle,
# usando hífens no lugar dos pontos. Ex.: 129-146-50-10.sslip.io
BASE_DOMAIN=203-0-113-10.sslip.io
PUBLIC_URL=https://api.203-0-113-10.sslip.io
FRONTEND_URL=https://crm.203-0-113-10.sslip.io

# Gere com: openssl rand -hex 32
APP_SECRET=COLE_UMA_CHAVE_ALEATORIA_AQUI

# Login que protege o CRM no navegador.
CRM_ADMIN_USER=admin
# Northflank: senha normal usada pelo login do navegador.
# Na Oracle com Caddy, este campo pode ficar vazio.
CRM_ADMIN_PASSWORD=
# Gere o hash com o comando indicado no guia. Não coloque senha simples aqui.
CRM_ADMIN_PASSWORD_HASH=COLE_O_HASH_BCRYPT_DO_CADDY

# Supabase > Connect > Session pooler > URI (porta 5432)
# Se a senha tiver caracteres especiais, use a versão codificada da URI.
DATABASE_URL=postgresql://postgres.PROJECT_REF:SENHA@aws-0-REGIAO.pooler.supabase.com:5432/postgres?sslmode=require

# Redis interno do Docker
REDIS_URL=redis://redis:6379/0

# Evolution API — gere todas as chaves; não reutilize senha pessoal
EVOLUTION_BASE_URL=http://evolution:8080
EVOLUTION_API_KEY=COLE_OUTRA_CHAVE_ALEATORIA
EVOLUTION_INSTANCE=empresa-principal
EVOLUTION_WEBHOOK_TOKEN=COLE_OUTRO_TOKEN_ALEATORIO
EVOLUTION_DB_PASSWORD=COLE_UMA_SENHA_FORTE_PARA_O_BANCO_LOCAL

# Google AI Studio > Get API key
GEMINI_API_KEY=COLE_A_CHAVE_DO_GEMINI
GEMINI_MODEL=gemini-3.5-flash
AI_ENABLED=true
AI_DEBOUNCE_SECONDS=8

# Empresa inicial
DEFAULT_COMPANY_SLUG=minha-empresa
DEFAULT_COMPANY_NAME="Minha Empresa"
DEFAULT_ACCESS_MESSAGE="Pagamento confirmado! Aqui está o seu acesso: {access_url}"
